# =============================================================
# NexusOps — Environment Variables
# =============================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed to git.
#
# Set ALL of these in Render → Environment tab before deploying.
# =============================================================

# ── Supabase (client-safe — safe for browser, enforces RLS) ──
VITE_SUPABASE_URL=https://dzwppsjnkwnlebnxaehu.supabase.co
VITE_SUPABASE_ANON_KEY=                         # Supabase project → Settings → API → anon public key

# ── Supabase (server-only — NEVER expose to the browser) ─────
SUPABASE_URL=https://dzwppsjnkwnlebnxaehu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                       # Supabase project → Settings → API → service_role key

# ── Database (Drizzle direct PostgreSQL connection) ───────────
# Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.dzwppsjnkwnlebnxaehu.supabase.co:5432/postgres

# ── Auth (tRPC JWT cookie sessions) ──────────────────────────
# Any long random string — used to sign session cookies.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── LLM Gateway (Forge API / Gemini 2.5 Flash) ───────────────
# Required for AI report generation and governance insights.
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=                          # Forge API key

# ── Airtable (server-only — never exposed to the browser) ────
# Required for Airtable → Supabase sync. Without this, the app
# falls back to Supabase data (or seed data if Supabase is empty).
AIRTABLE_API_KEY=                                # Airtable → Account → Developer hub → Personal access tokens
AIRTABLE_BASE_ID=app4DDa3zvaGspOhz              # Governance base ID (change only if you recreate the base)

# ── Make.com runtime (optional) ──────────────────────────────
# Added as x-make-apikey header when dispatching to Make webhooks.
MAKE_API_KEY=

# ── Webhook HMAC secrets (optional) ─────────────────────────
# Generate with: openssl rand -hex 32
# Leave empty to skip signature verification (not recommended for production).
MAKE_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET=

# ── Stripe ───────────────────────────────────────────────────
# Required for billing / subscription features.
# Use sk_test_... during development, sk_live_... in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=                       # Stripe dashboard → Webhooks → signing secret

# ── Anthropic (direct key, fallback if Forge is unavailable) ─
ANTHROPIC_API_KEY=

# ── PayPal ───────────────────────────────────────────────────
# Create app at https://developer.paypal.com/developer/applications
# Use sandbox credentials during development, live in production.
PAYPAL_CLIENT_ID=                            # PayPal app → Client ID (also set VITE_PAYPAL_CLIENT_ID)
PAYPAL_CLIENT_SECRET=                        # PayPal app → Secret key (server-only, never expose to browser)
PAYPAL_SANDBOX=true                          # "false" for production live payments

# ── M-Pesa / Safaricom Daraja ────────────────────────────────
# Create app at https://developer.safaricom.co.ke
# Sandbox shortcode: 174379, passkey is available in Daraja portal
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORTCODE=174379             # Sandbox: 174379 | Production: your Paybill/Till number
MPESA_PASSKEY=                              # Daraja → My Apps → STK Push Passkey
MPESA_CALLBACK_URL=                         # Must be a publicly reachable HTTPS URL (e.g. Render URL + /api/mpesa/callback)
MPESA_SANDBOX=true                          # "false" for production

# ── Airtable client-side (Vite — bundled into browser) ───────
# Read-only token for client-side hooks (useTourContent, usePricing, etc.)
VITE_AIRTABLE_TOKEN=                         # Airtable personal access token (read-only scope)
VITE_AIRTABLE_BASE_ID=app4DDa3zvaGspOhz

# ── PayPal client-side (Vite — visible in browser bundle) ────
# This is the CLIENT ID only — never put the secret here
VITE_PAYPAL_CLIENT_ID=                       # Same as PAYPAL_CLIENT_ID above (safe to expose)

# ── CORS ─────────────────────────────────────────────────────
# Production: set to your Render static site URL or custom domain.
CLIENT_ORIGIN=http://localhost:5173
